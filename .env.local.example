# === Configuração do Supabase ===
# Pegue esses valores em: Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica-aqui

# === Email do administrador ===
# O email do Google que terá acesso ao painel de admin.
# Você pode colocar mais de um separando por vírgula.
NEXT_PUBLIC_ADMIN_EMAILS=seu-email@gmail.com

# === Chave secreta de administrador (NUNCA compartilhe) ===
# Supabase > Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta-aqui

# === Token da API de resultados (Football-Data.org) ===
# Crie conta grátis em https://www.football-data.org/client/register
# O plano grátis cobre a Copa do Mundo. Cole aqui seu token (X-Auth-Token).
# Sem isso, você ainda pode lançar os placares na mão pelo painel.
FOOTBALL_DATA_TOKEN=seu-token-football-data-aqui

# === Chave da API-Football (tela de Craques / artilheiros) ===
# Crie conta grátis em https://www.api-football.com (ou via RapidAPI)
# Plano grátis: ~100 requisições/dia. Sem isso, a tela de Craques fica vazia.
API_FOOTBALL_KEY=sua-chave-api-football-aqui
